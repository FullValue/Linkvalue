# ---------------------------------------------------------------------------
# Supabase — Project Settings → Data API / API Keys
# ---------------------------------------------------------------------------

# Public project URL, e.g. https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose; RLS protects the data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service_role secret. Bypasses RLS — used by analytics tracking.
# NEVER expose this to the browser or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------

# Absolute base URL of the deployment. Used for Open Graph tags and the
# "copy public link" feature. Locally this is http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional. Root domain for per-handle subdomains, e.g. "lumen.app" so pages
# live at "<handle>.lumen.app". Requires a wildcard domain (*.lumen.app) on the
# host. Leave empty to use path-based URLs (<site>/handle) — the default on
# *.vercel.app and localhost, where wildcard subdomains aren't available.
NEXT_PUBLIC_ROOT_DOMAIN=
